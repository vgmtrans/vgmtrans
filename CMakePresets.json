{
    "version": 3,
    "configurePresets": [
        {
            "name": "windows-base",
            "hidden": true,
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "environment": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            },
            "cacheVariables": {
                "CMAKE_CXX_SCAN_FOR_MODULES": false
            }
        },
        {
            "name": "win-x64",
            "inherits": "windows-base",
            "displayName": "Windows x64 (MSVC)",
            "description": "Build VGMTrans for Windows x64 using MSVC",
            "toolchainFile": "${sourceDir}/cmake/toolchain/windows-x64.cmake",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            }
        },
        {
            "name": "win-arm64",
            "inherits": "windows-base",
            "displayName": "Windows ARM64 (MSVC)",
            "description": "Build VGMTrans for Windows ARM64 using MSVC",
            "toolchainFile": "${sourceDir}/cmake/toolchain/windows-arm64.cmake",
            "architecture": {
                "value": "arm64",
                "strategy": "external"
            },
            "cacheVariables": {
                "ENABLE_UI_QT": false
            }
        },
        {
            "name": "win-x64-clang",
            "inherits": "windows-base",
            "displayName": "Windows x64 (Clang)",
            "description": "Build VGMTrans for Windows x64 using Clang",
            "toolchainFile": "${sourceDir}/cmake/toolchain/windows-x64.cmake",
            "environment": {
                "CC": "clang-cl.exe",
                "CXX": "clang-cl.exe",
                "LDFLAGS": "-fuse-ld=lld"
            },
            "cacheVariables": {
                "WITH_LZMA_ASM": false
            }
        },
        {
            "name": "macos-base",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "environment": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_PREFIX_PATH": "/usr/local/include:/usr/local/opt/qt6"
            },
            "cacheVariables": {
                "CMAKE_CXX_SCAN_FOR_MODULES": false
            }
        },
        {
            "name": "macos-intel",
            "inherits": "macos-base",
            "displayName": "VGMTrans (Intel)",
            "description": "Build VGMTrans for Intel Macs",
            "toolchainFile": "${sourceDir}/cmake/toolchain/macOS-Intel.cmake",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "macos-arm64",
            "inherits": "macos-base",
            "displayName": "VGMTrans (Apple Silicon)",
            "description": "Build VGMTrans for Apple Silicon Macs",
            "toolchainFile": "${sourceDir}/cmake/toolchain/macOS-AppleSilicon.cmake",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "linux-x64",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "displayName": "Linux x64",
            "description": "Build VGMTrans for Linux x64",
            "toolchainFile": "${sourceDir}/cmake/toolchain/Linux-x64.cmake",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "environment": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            },
            "cacheVariables": {
                "CMAKE_CXX_SCAN_FOR_MODULES": false
            }
        }
    ],
    "buildPresets": [
        {
            "name": "win-x64-debug",
            "displayName": "Windows x64, Debug",
            "configurePreset": "win-x64",
            "configuration": "Debug"
        },
        {
            "name": "win-x64-release",
            "displayName": "Windows x64, Release",
            "configurePreset": "win-x64",
            "configuration": "Release"
        },
        {
            "name": "win-x64-clang-debug",
            "displayName": "Windows x64, Debug (Clang)",
            "configurePreset": "win-x64-clang",
            "configuration": "Debug"
        },
        {
            "name": "win-x64-clang-release",
            "displayName": "Windows x64, Release (Clang)",
            "configurePreset": "win-x64-clang",
            "configuration": "Release"
        },
        {
            "name": "win-arm64-debug",
            "displayName": "Windows ARM64, Debug",
            "configurePreset": "win-arm64",
            "configuration": "Debug"
        },
        {
            "name": "win-arm64-release",
            "displayName": "Windows ARM64, Release",
            "configurePreset": "win-arm64",
            "configuration": "Release"
        },
        {
            "name": "win-x64-asan-debug",
            "displayName": "Windows x64 ASAN, Debug",
            "configurePreset": "win-x64",
            "configuration": "Debug",
            "environment": {
                "CFLAGS": "/fsanitize=address",
                "CXXFLAGS": "/fsanitize=address"
            }
        },
        {
            "name": "macos-intel-debug",
            "displayName": "macOS Intel, Debug",
            "configurePreset": "macos-intel",
            "configuration": "Debug"
        },
        {
            "name": "macos-intel-release",
            "displayName": "macOS Intel, Release",
            "configurePreset": "macos-intel",
            "configuration": "Release"
        },
        {
            "name": "macos-arm64-debug",
            "displayName": "macOS Apple Silicon, Debug",
            "configurePreset": "macos-arm64",
            "configuration": "Debug"
        },
        {
            "name": "macos-arm64-release",
            "displayName": "macOS Apple Silicon, Release",
            "configurePreset": "macos-arm64",
            "configuration": "Release"
        },
        {
            "name": "macos-intel-asan-debug",
            "displayName": "macOS Intel ASAN, Debug",
            "configurePreset": "macos-intel",
            "configuration": "Debug",
            "environment": {
                "CFLAGS": "-fsanitize=address -fno-omit-frame-pointer",
                "CXXFLAGS": "-fsanitize=address -fno-omit-frame-pointer",
                "LDFLAGS": "-fsanitize=address"
            }
        },
        {
            "name": "macos-arm64-asan-debug",
            "displayName": "macOS Apple Silicon ASAN, Debug",
            "configurePreset": "macos-arm64",
            "configuration": "Debug",
            "environment": {
                "CFLAGS": "-fsanitize=address -fno-omit-frame-pointer",
                "CXXFLAGS": "-fsanitize=address -fno-omit-frame-pointer",
                "LDFLAGS": "-fsanitize=address"
            }
        },
        {
            "name": "linux-x64-debug",
            "displayName": "Linux x64, Debug",
            "configurePreset": "linux-x64",
            "configuration": "Debug"
        },
        {
            "name": "linux-x64-release",
            "displayName": "Linux x64, Release",
            "configurePreset": "linux-x64",
            "configuration": "Release"
        },
        {
            "name": "linux-x64-asan-debug",
            "displayName": "Linux x64 ASAN, Debug",
            "configurePreset": "linux-x64",
            "configuration": "Debug",
            "environment": {
                "CFLAGS": "-fsanitize=address -fno-omit-frame-pointer",
                "CXXFLAGS": "-fsanitize=address -fno-omit-frame-pointer",
                "LDFLAGS": "-fsanitize=address"
            }
        }
    ]
}